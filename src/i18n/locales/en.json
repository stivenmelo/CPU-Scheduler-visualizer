  "algorithms": {
    "FCFS": {
      "name": "First Come First Served",
      "short": "FCFS",
      "description": "Processes are executed in the order they arrive. Simple and fair by arrival order.",
      "type": "Non-Preemptive",
      "complexity": "O(n)",
      "pros": ["Simple to implement", "No starvation", "Fair in arrival order"],
      "cons": ["High average waiting time", "Convoy effect", "Not suitable for interactive systems"]
    },
    "SJF": {
      "name": "Shortest Job First",
      "short": "SJF",
      "description": "When the CPU is free, it selects the process with the shortest burst time.",
      "type": "Non-Preemptive",
      "complexity": "O(n log n)",
      "pros": ["Minimizes average waiting time", "Good throughput"],
      "cons": ["Starvation of long processes", "Burst time must be known in advance"]
    },
    "SRTF": {
      "name": "Shortest Remaining Time First",
      "short": "SRTF",
      "description": "Preemptive version of SJF. If a new process arrives with shorter remaining time, it preempts the current one.",
      "type": "Preemptive",
      "complexity": "O(n log n)",
      "pros": ["Optimal average waiting time", "Responsive to short jobs"],
      "cons": ["High context switch overhead", "Starvation possible", "Burst time must be predicted"]
    },
    "RR": {
      "name": "Round Robin",
      "short": "Round Robin",
      "description": "Each process gets a fixed time quantum. After the quantum expires, the process goes to the back of the queue.",
      "type": "Preemptive",
      "complexity": "O(n)",
      "pros": ["Fair allocation", "Good for time-sharing systems", "No starvation"],
      "cons": ["Performance depends on quantum size", "High context switch overhead if quantum is too small"]
    },
    "PRIORITY_NP": {
      "name": "Priority (Non-Preemptive)",
      "short": "Priority NP",
      "description": "Processes are scheduled by priority. Once a process starts, it runs to completion.",
      "type": "Non-Preemptive",
      "complexity": "O(n²)",
      "pros": ["Important tasks run first", "Simple logic"],
      "cons": ["Starvation of low-priority processes", "Aging needed to prevent starvation"]
    },
    "PRIORITY_P": {
      "name": "Priority (Preemptive)",
      "short": "Priority P",
      "description": "If a higher-priority process arrives, it immediately preempts the currently running process.",
      "type": "Preemptive",
      "complexity": "O(n log n)",
      "pros": ["Highly responsive to priority tasks", "Used in real-time systems"],
      "cons": ["Starvation risk", "Many context switches", "Complex implementation"]
    }
  },
